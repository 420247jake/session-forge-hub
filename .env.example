# session-forge hub configuration

# Server port (default: 3700)
PORT=3700

# Bind address (default: 0.0.0.0 — change to 127.0.0.1 for localhost-only)
HOST=0.0.0.0

# Data directory (default: ~/.session-forge-hub or %APPDATA%/session-forge-hub)
# SESSION_FORGE_HUB_DIR=/path/to/data

# Stripe (optional — for donations/tips)
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_PUBLISHABLE_KEY=pk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# Hub name (shown in dashboard header)
HUB_NAME=session-forge hub

# Max registered agents (default: 50)
MAX_AGENTS=50

# Data retention in days (default: 90)
RETENTION_DAYS=90
